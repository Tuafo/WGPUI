+        crate::LayoutFrame {
+            handled: true,
+            ..Default::default()
+        }
+    }
+
+    fn prepaint_begin(&mut self, ctx: &mut crate::PrepaintCtx) -> crate::PrepaintFrame {
+        // Call prepare_prepaint to set up hitbox and event handlers
+        let hitbox = self.interactivity.prepaint(
+            Some(&ctx.fiber_id),
