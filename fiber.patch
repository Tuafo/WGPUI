+        resolved.offset[0] = resolved.offset[0] * t.scale + t.offset[0];
+        resolved.offset[1] = resolved.offset[1] * t.scale + t.offset[1];
+        resolved.scale *= t.scale;
+        current = t.parent_index;
+    }
+    resolved
+}
