+        // Prepare prepaint to set up hitbox
+        let prepaint = self.interactivity.prepare_prepaint(
+            ctx.fiber_id,
+            ctx.inspector_id.as_ref(),
+            ctx.bounds,
+            content_size,
+            ctx.window,
+            ctx.cx,
