+
+        // Call prepare_paint
+        let Some(paint) = self.interactivity.prepare_paint(
+            ctx.fiber_id,
+            ctx.bounds,
+            hitbox.as_ref(),
+            ctx.window,
+            ctx.cx,
+        ) else {
