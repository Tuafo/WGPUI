+pub(crate) fn path_to_root_smallvec(
+    tree: &FiberTree,
+    id: GlobalElementId,
+) -> SmallVec<[GlobalElementId; 32]> {
+    let mut path = SmallVec::new();
+    let mut current = Some(id);
+    while let Some(node_id) = current {
+        path.push(node_id);
+        current = tree.parent(&node_id);
+    }
+    path.reverse();
+    path
+}
