+            ScaledPixels(bounds.origin.y.0 * t.scale + t.offset[1]),
+        ),
+        size: Size {
+            width: ScaledPixels(bounds.size.width.0 * t.scale),
+            height: ScaledPixels(bounds.size.height.0 * t.scale),
+        },
+    }
+}
